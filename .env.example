# Environment variables for The Empathy Engine
# Copy this file to .env and fill in your actual values

# Enable Hugging Face neural TTS for third comparison voice
EMPATHY_ENABLE_HF_TTS=true

# Your Hugging Face API token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=your_hugging_face_token_here

# Optional: Other configuration overrides
# EMPATHY_EMOTION_BACKEND=huggingface
# EMPATHY_HF_EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
# EMPATHY_HF_TTS_MODEL=parler-tts/parler-tts-mini-expresso
# EMPATHY_HF_TTS_SPEAKER=Elisabeth